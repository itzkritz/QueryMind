# Supabase PostgreSQL Database Connection Configuration
# Retrieve these credentials from your Supabase Dashboard: Project Settings -> Database -> Connection Info

DB_HOST=your-project-id.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-secure-database-password

# Path to the local CSV files folder (e.g. c:/Users/ACER/Downloads/sales)
SALES_DATA_DIR=c:/Users/ACER/Downloads/sales

# LLM Provider Keys (add the one(s) you want to use)
GOOGLE_API_KEY=your-google-gemini-api-key
HF_TOKEN=your-huggingface-inference-token

# Ollama local host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
