# Supabase PostgreSQL Metadata Database Connection Configuration
# Retrieve these credentials from your Supabase Dashboard: Project Settings -> Database -> Connection Info
DB_HOST=your-project-id.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-secure-database-password

# Base64 Fernet Key used for encrypting user-connected database passwords.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-32-byte-base64-encryption-key

# JWT Validation for Supabase Auth
# Retrieve the secret from: Supabase Dashboard -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
AUTH_REQUIRED=false

# Google Gemini API Key for Text-to-SQL generation
GOOGLE_API_KEY=your-google-gemini-api-key

# Ollama local host (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
