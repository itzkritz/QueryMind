# ─────────────────────────────────────────────────────────────
#  QueryMind — .gitignore
#  NEVER commit real credentials or user-uploaded data.
# ─────────────────────────────────────────────────────────────

# ── Secrets & environment variables ──────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.cert
*.p12

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
.Python
*.egg
*.egg-info/
eggs/
.installed.cfg

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Pytest / coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Node / frontend ───────────────────────────────────────────
node_modules/
client/node_modules/
client/dist/
client/.cache/
client/.vite/
.npm/

# ── SQLite user-uploaded databases ────────────────────────────
server/uploads/
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# ── Large sample/seed data files ──────────────────────────────
sales/
*.csv
*.xlsx
*.xls
*.parquet

# ── Stray config files accidentally placed in server/ ─────────
server/tsconfig*.json
server/vite.config.*
server/jsconfig.json

# ── IDE & editor ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS junk ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Streamlit (legacy) ────────────────────────────────────────
.streamlit/secrets.toml
